{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nunchi.invalid/schemas/v2/attention-receipt.schema.json",
  "title": "AttentionReceiptV2",
  "description": "I-010E AttentionReceiptV2@1 — one immutable stage record of the request-correlated receipt stream, encoding each stage's selected telemetry verbatim (FR-014, c834e8c): observation records the schema version, trigger and continuity-scope IDs, snapshot sizes, coverage, and included event IDs; attention records classifier and effective dispositions, classifier identity, evidence, and transition-valve facts, or the bypass fact `classifier_not_invoked` with cause and trusted policy provenance, with operational error kept separate; participant-host records the wake source, packet sizes, delivered event IDs, expansion calls, invocation, and the observed sent/silent/unknown outcome; transport records delivery hygiene, routing/send facts, and transport errors. The canonical order is observation -> attention -> participant-host -> transport; a prefix-partial receipt is valid-in-progress. The stage-to-writer binding is part of this public per-record contract (FR-010, rejection R3): the closed map is observation -> observation-provider, attention -> attention-engine, participant-host -> participant-host, transport -> transport, and a record attributing one stage to another stage's owner is invalid as a single document. The multi-record rules — append-only sequence, canonical order, immutability, request-ID correlation, and stream-level writer ownership — span multiple records and remain runtime-adapter-only in addition (FR-012 receipt-stage sequence class). Unknown and unavailable remain explicit.",
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "disposition": {"enum": ["SUPPRESS", "WAKE", "DEFER"]},
    "observationBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "trigger_event_id", "continuity_scope_id", "event_count", "byte_count", "coverage", "included_event_ids"],
      "properties": {
        "schema_version": {"const": 2},
        "trigger_event_id": {"$ref": "#/$defs/nonEmptyString"},
        "continuity_scope_id": {"$ref": "#/$defs/nonEmptyString"},
        "event_count": {"type": "integer", "minimum": 0},
        "byte_count": {"type": "integer", "minimum": 0},
        "coverage": {"$ref": "https://nunchi.invalid/schemas/v2/attention-request.schema.json#/$defs/coverage"},
        "included_event_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/nonEmptyString"}
        }
      }
    },
    "attentionBody": {
      "oneOf": [
        {
          "$comment": "Classifier outcome with effective routing (transition-valve facts) and classifier identity/evidence.",
          "type": "object",
          "additionalProperties": false,
          "required": ["classifier_disposition", "effective_disposition", "classifier", "evidence_event_ids", "routing_audit"],
          "properties": {
            "classifier_disposition": {"$ref": "#/$defs/disposition"},
            "effective_disposition": {"$ref": "#/$defs/disposition"},
            "classifier": {"$ref": "https://nunchi.invalid/schemas/v2/attention-decision.schema.json#/$defs/classifierAudit"},
            "evidence_event_ids": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonEmptyString"}
            },
            "routing_audit": {"$ref": "https://nunchi.invalid/schemas/v2/attention-decision.schema.json#/$defs/routingAudit"}
          }
        },
        {
          "$comment": "Operational error, kept separate from any social outcome.",
          "type": "object",
          "additionalProperties": false,
          "required": ["error"],
          "properties": {
            "error": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "detail"],
              "properties": {
                "code": {"$ref": "#/$defs/nonEmptyString"},
                "detail": {"type": "string"}
              }
            }
          }
        },
        {
          "$comment": "Trusted bypass: no classifier was invoked and no social result is fabricated.",
          "type": "object",
          "additionalProperties": false,
          "required": ["classifier_not_invoked", "cause", "policy_provenance"],
          "properties": {
            "classifier_not_invoked": {"const": true},
            "cause": {"const": "preattention-disabled"},
            "policy_provenance": {"$ref": "#/$defs/nonEmptyString"}
          }
        }
      ]
    },
    "participantHostBody": {
      "$comment": "Participant silence is a distinct staged outcome — separate from model suppression and from non-invocation — with no handled/owed/obligation state. The observed outcome is sent/silent/unknown (FR-014), not a handled/owed social state.",
      "type": "object",
      "additionalProperties": false,
      "required": ["wake_source", "packet_event_count", "packet_byte_count", "delivered_event_ids", "expansion_calls", "invoked", "outcome"],
      "properties": {
        "wake_source": {"enum": ["WAKE", "DEFER", "ERROR_FALLBACK", "PREATTENTION_BYPASS"]},
        "packet_event_count": {"type": "integer", "minimum": 0},
        "packet_byte_count": {"type": "integer", "minimum": 0},
        "delivered_event_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/nonEmptyString"}
        },
        "expansion_calls": {"type": "integer", "minimum": 0},
        "invoked": {"type": "boolean"},
        "outcome": {"enum": ["sent", "silent", "unknown"]}
      }
    },
    "transportBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delivery"],
      "properties": {
        "delivery": {"enum": ["sent", "failed", "unknown", "unavailable"]},
        "detail": {"type": "string"}
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "stage", "writer", "body"],
  "properties": {
    "request_id": {"$ref": "#/$defs/nonEmptyString"},
    "stage": {"enum": ["observation", "attention", "participant-host", "transport"]},
    "writer": {"enum": ["observation-provider", "attention-engine", "participant-host", "transport"]},
    "body": {"type": "object"}
  },
  "allOf": [
    {
      "$comment": "FR-010 per-record stage-to-writer binding: each stage is written only by its single directly observing owner; a cross-owner record is invalid as a single document.",
      "if": {"required": ["stage"], "properties": {"stage": {"const": "observation"}}},
      "then": {
        "properties": {
          "writer": {"const": "observation-provider"},
          "body": {"$ref": "#/$defs/observationBody"}
        }
      }
    },
    {
      "if": {"required": ["stage"], "properties": {"stage": {"const": "attention"}}},
      "then": {
        "properties": {
          "writer": {"const": "attention-engine"},
          "body": {"$ref": "#/$defs/attentionBody"}
        }
      }
    },
    {
      "if": {"required": ["stage"], "properties": {"stage": {"const": "participant-host"}}},
      "then": {
        "properties": {
          "writer": {"const": "participant-host"},
          "body": {"$ref": "#/$defs/participantHostBody"}
        }
      }
    },
    {
      "if": {"required": ["stage"], "properties": {"stage": {"const": "transport"}}},
      "then": {
        "properties": {
          "writer": {"const": "transport"},
          "body": {"$ref": "#/$defs/transportBody"}
        }
      }
    }
  ]
}
