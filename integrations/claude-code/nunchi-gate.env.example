# Nunchi Claude Code gate — operator identity (EXAMPLE)
#
# Copy this to ~/.claude/nunchi-gate.env and edit for your agent. The Nunchi
# installer writes the fail-open *wrappers* that source this file, but it never
# writes or overwrites the env file itself — so your identity survives every
# `nunchi-install upgrade`. This is the sturdy home for hook config; do not put
# identity inline in the wrappers (the installer will replace them).
#
# Both the inbound (user-prompt-submit) and outbound (pretool-reply) wrappers
# source this shared file. For a value that must differ per direction, add a
# per-hook override file next to this one — it is sourced AFTER the shared file,
# so its exports win:
#
#   ~/.claude/nunchi-pretool-reply.env       (outbound reply gate override)
#   ~/.claude/nunchi-user-prompt-submit.env  (inbound gate override)
#
# See nunchi-pretool-reply.env.example for the canonical per-direction case.

# --- shared classifier secrets ------------------------------------------------
# The gate binary calls the classifier and needs its credentials. Pull them from
# wherever you already keep them (here: a Hermes .env). The `set -a` block
# exports every variable the sourced file defines; drop it if you export inline.
set -a
[ -f "$HOME/.hermes/.env" ] && . "$HOME/.hermes/.env"
set +a

# --- agent identity -----------------------------------------------------------
# Who this agent is, so the gate can recognise its own messages and @-mentions.
export NUNCHI_HOOK_AGENT_ID="agent"                 # short id sent in the payload
export NUNCHI_HOOK_ALIASES="Agent"                  # comma-separated display names
export NUNCHI_HOOK_MENTION_ID="000000000000000000"  # this agent's mention snowflake

# --- peer roster (shared default) ---------------------------------------------
# Other bots in the room. Their messages are tagged author_kind "peer_bot" (vs
# "human"), which the classifier weighs when deciding admission. This shared
# value is the DEFAULT for both directions; narrow it per-direction in an
# override file if needed.
export NUNCHI_HOOK_PEER_BOTS="PeerA,PeerB"

# --- gate binary --------------------------------------------------------------
export NUNCHI_CHANNEL_BIN="$HOME/.local/bin/nunchi-channel"
