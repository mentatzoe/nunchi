# nunchi-claude-v2.env — trusted operator configuration for the Nunchi V2
# Claude Code integration. Copy to ~/.claude/nunchi-claude-v2.env (0600).
# The hook wrapper sources this file; nothing here may come from room content
# or model output, and no credential belongs in this file: the classifier
# endpoint, model, and API key live in the owner-only operator policy JSON.

# Operator policy file (I-030A/I-040B trusted policy; owner-only 0600).
# Attention budgets, the transition DEFER margin, trusted preattention
# bypass, error action, authorization grants, and the receipt-sink directory
# all live here — the V1 NUNCHI_DEFER* / NUNCHI_CLASSIFIER_* variables are
# gone with the V1 gate.
NUNCHI_CLAUDE_V2_POLICY="$HOME/.claude/nunchi/claude-v2-policy.json"

# Owner-only state directory (bounded event retention, scheduler facts, the
# active turn record). Created 0700 on first use.
NUNCHI_CLAUDE_V2_STATE_DIR="$HOME/.claude/nunchi/claude-v2-state"

# Exact room binding: one Discord channel snowflake, and the bot's own exact
# native user ID. Display names and aliases never establish identity.
NUNCHI_CLAUDE_V2_CHANNEL_ID="000000000000000000"
NUNCHI_CLAUDE_V2_SELF_USER_ID="000000000000000000"

# Participant binding: must equal attention.participant_id in the policy.
NUNCHI_CLAUDE_V2_PARTICIPANT_ID="claude-station"
# Loose descriptive name (evidence for the model, never identity).
NUNCHI_CLAUDE_V2_PARTICIPANT_NAME="Station"

# Transport native-fact sidecar written by the patched Discord plugin
# (transport-owned; this integration only reads it).
#NUNCHI_CLAUDE_V2_SIDECAR="$HOME/.claude/channels/discord/nunchi-native-events.jsonl"

# Optional deterministic tool classification map (room-action transport tool
# patterns plus privileged tool -> capability entries for the I-040B guard).
# Without it the guard enforces nothing and the packet reports the guard as
# unenforced.
#NUNCHI_CLAUDE_V2_TOOLS="$HOME/.claude/nunchi/claude-v2-tools.json"
