+import { readFileSync, writeFileSync, mkdirSync, readdirSync, rmSync, statSync, renameSync, realpathSync, chmodSync, appendFileSync } from 'fs'
 import { homedir } from 'os'
 import { join, sep } from 'path'
 
@@ -40,6 +40,45 @@ const ACCESS_FILE = join(STATE_DIR, 'access.json')
 const APPROVED_DIR = join(STATE_DIR, 'approved')
 const ENV_FILE = join(STATE_DIR, '.env')
 
+// Nunchi V2 native-fact sidecar. The channel tag rendered from the meta of
+// the inbound notification does not carry the exact author ID, bot flag,
+// mention IDs, or the reply reference, and the referenced-message author and
+// content are not synchronously known here. This transport process appends
+// the exact facts it does hold, one JSON line per delivered message, so a V2
+// consumer can bind identity and relations without guessing from display
+// names. Mechanical fact recording only: no filtering, no policy, and no
+// social meaning. Absent facts stay absent.
+const NATIVE_FACT_LOG = join(STATE_DIR, 'nunchi-native-events.jsonl')
+const NATIVE_FACT_LOG_MAX_BYTES = 8 * 1024 * 1024
+
+function recordNativeFacts(msg: Message): void {
+  try {
+    try {
+      if (statSync(NATIVE_FACT_LOG).size > NATIVE_FACT_LOG_MAX_BYTES) {
+        renameSync(NATIVE_FACT_LOG, NATIVE_FACT_LOG + '.1')
+      }
+    } catch {}
+    appendFileSync(
+      NATIVE_FACT_LOG,
+      JSON.stringify({
+        v: 1,
+        delivered_at: new Date().toISOString(),
+        guild_id: msg.guildId ?? null,
+        channel_id: msg.channelId,
+        message_id: msg.id,
+        author: { id: msg.author.id, username: msg.author.username, bot: msg.author.bot },
+        content: msg.content,
+        timestamp: msg.createdAt.toISOString(),
+        mention_user_ids: [...msg.mentions.users.keys()],
+        mention_everyone: msg.mentions.everyone,
+        reply_to_message_id: msg.reference?.messageId ?? null,
+      }) + '\n',
+    )
+  } catch (err) {
+    process.stderr.write(`discord channel: native-fact record failed: ${err}\n`)
+  }
+}
+
 // Load ~/.claude/channels/discord/.env into process.env. Real env wins.
 // Plugin-spawned servers don't get an env block — this is where the token lives.
 try {
@@ -990,6 +1029,8 @@ async function handleInbound(msg: Message): Promise<void> {
     transcripts.length > 0 ? `\n\n[Voice transcript]\n${transcripts.join('\n\n')}` : ''
   const content = `${baseContent}${transcriptBlock}`.trim()
 
+  recordNativeFacts(msg)
