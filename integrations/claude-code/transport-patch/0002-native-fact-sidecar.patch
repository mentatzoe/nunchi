+// -------------------------------------------------------------------------
+// Nunchi V2 native-fact sidecar (transport-owned). The channel tag rendered
+// into the inbound notification omits the exact author ID, bot flag, mention
+// IDs, guild, and reply reference. This transport process appends the exact
+// facts it holds, one JSON line per message, so a V2 consumer can bind
+// identity and native relations without guessing from display names.
+//
+// It carries verbatim room content, so it is kept OWNER-ONLY: written into a
+// caller-owned directory validated to mode 0700 (non-symlink, non-shared),
+// as a file created 0600, opened O_NOFOLLOW, and validated as an owner-owned
+// regular file before every write. An unsafe directory or file is refused
+// (fail closed) rather than written; a pre-existing 0755/0777/symlinked/
+// non-directory path is rejected, never silently reused. Records are
+// validated/serialized before writing; an unserializable record is dropped,
+// never partially written. Mechanical fact recording only: no filtering, no
+// policy, no social meaning.
+// -------------------------------------------------------------------------
+const NUNCHI_SIDECAR_DIR = join(STATE_DIR, 'nunchi-v2')
+const NATIVE_FACT_LOG = join(NUNCHI_SIDECAR_DIR, 'native-events.jsonl')
+const NATIVE_FACT_LOG_MAX_BYTES = 8 * 1024 * 1024
+
+function nunchiSidecarDirIsSafe() {
+  // Create the owner-only directory if absent; then validate the existing
+  // directory is a caller-owned, non-symlink directory with mode 0700.
+  // A pre-existing unsafe (0755/0777/symlink/non-directory) path is rejected.
+  try { mkdirSync(NUNCHI_SIDECAR_DIR, { recursive: true, mode: 0o700 }) } catch {}
+  let ds
+  try { ds = lstatSync(NUNCHI_SIDECAR_DIR) } catch { return false }
+  const duid = typeof process.getuid === 'function' ? process.getuid() : ds.uid
+  if (ds.isSymbolicLink() || !ds.isDirectory() || ds.uid !== duid || (ds.mode & 0o077) !== 0) {
+    return false
+  }
+  return true
+}
+
+function recordNativeFacts(msg, content, attachments, transcripts, delivered) {
+  let fd = -1
+  try {
+    if (!nunchiSidecarDirIsSafe()) {
+      process.stderr.write('discord: native-fact sidecar directory is unsafe (must be owner-only 0700); refusing to record\n')
+      return
+    }
+    // Best-effort size rotation using a no-follow stat: never rotate a symlink.
+    try {
+      const ls = lstatSync(NATIVE_FACT_LOG)
+      if (ls.isFile() && ls.size > NATIVE_FACT_LOG_MAX_BYTES) {
+        renameSync(NATIVE_FACT_LOG, NATIVE_FACT_LOG + '.1')
+      }
+    } catch {}
+    const flags = constants.O_WRONLY | constants.O_CREAT | constants.O_APPEND |
+      constants.O_NOFOLLOW | constants.O_CLOEXEC
+    fd = openSync(NATIVE_FACT_LOG, flags, 0o600)
+    const st = fstatSync(fd)
+    const uid = typeof process.getuid === 'function' ? process.getuid() : st.uid
+    if (!st.isFile() || st.uid !== uid || (st.mode & 0o077) !== 0) {
+      process.stderr.write('discord: native-fact sidecar file is unsafe (must be owner-only 0600); refusing to record\n')
+      return
+    }
+    let line
+    try {
+      line = JSON.stringify({
+        v: 1,
+        delivered,
+        delivered_at: new Date().toISOString(),
+        guild_id: msg.guildId ?? null,
+        channel_id: msg.channelId,
+        message_id: msg.id,
+        author: { id: msg.author.id, username: msg.author.username, bot: msg.author.bot },
+        content,
+        attachments,
+        transcripts,
+        timestamp: msg.createdAt.toISOString(),
+        mention_user_ids: [...msg.mentions.users.keys()],
+        mention_everyone: msg.mentions.everyone,
+        reply_to_message_id: msg.reference?.messageId ?? null,
+      }) + '\n'
+    } catch (err) {
+      process.stderr.write(`discord: native-fact record not serializable; dropped: ${err}\n`)
+      return
+    }
+    writeSync(fd, line)
+  } catch (err) {
+    process.stderr.write(`discord: native-fact record failed: ${err}\n`)
+  } finally {
+    if (fd >= 0) { try { closeSync(fd) } catch {} }
+  }
+}
+
 // Load ~/.claude/channels/discord/.env into process.env. Real env wins.
