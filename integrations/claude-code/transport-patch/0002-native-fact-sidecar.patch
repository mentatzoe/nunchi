+    // these from the sidecar and retains them as SELF_RETAINED_NO_WAKE.
+    recordNativeFacts(msg, msg.content, [], [], false)
+    return
+  }
   handleInbound(msg).catch(e => process.stderr.write(`discord: handleInbound failed: ${e}\n`))
 })
 
@@ -990,6 +1084,10 @@ async function handleInbound(msg: Message): Promise<void> {
     transcripts.length > 0 ? `\n\n[Voice transcript]\n${transcripts.join('\n\n')}` : ''
   const content = `${baseContent}${transcriptBlock}`.trim()
 
+  // Record the exact content delivered to Claude — attachment
