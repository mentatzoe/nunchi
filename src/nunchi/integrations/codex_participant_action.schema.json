{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NunchiCodexParticipantResultV2",
  "description": "Integration-private structured result: one ordinary room action or explicit silence. The host, not Codex, executes it.",
  "type": "object",
  "additionalProperties": false,
  "required": ["action"],
  "properties": {
    "action": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "content"],
          "properties": {
            "kind": {"const": "message"},
            "content": {"type": "string", "minLength": 1, "maxLength": 2000},
            "reply_to_event_id": {"type": "string", "minLength": 1},
            "mention_actor_ids": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "target_event_id", "reaction"],
          "properties": {
            "kind": {"const": "reaction"},
            "target_event_id": {"type": "string", "minLength": 1},
            "reaction": {"type": "string", "minLength": 1, "maxLength": 256}
          }
        }
      ]
    }
  }
}
